{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "framework": "nextjs",
      "entrypoint": "frontend/package.json"
    },
    "api": {
      "entrypoint": "api/index.py"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
