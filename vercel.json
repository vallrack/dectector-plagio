{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/"
    },
    "api": {
      "routePrefix": "/api"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
